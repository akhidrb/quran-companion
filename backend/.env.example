# ── Supabase (https://supabase.com) ──────────────────────────────────────────
# 1. Enable pgvector: run "CREATE EXTENSION IF NOT EXISTS vector;" in SQL Editor
# 2. Run supabase/migrations/001_verses.sql
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI (https://platform.openai.com) ─────────────────────────────────────
# Used for text-embedding-3-small embeddings
OPENAI_API_KEY=sk-...

# ── Anthropic (https://console.anthropic.com) ────────────────────────────────
# Used for Claude generation
ANTHROPIC_API_KEY=sk-ant-...

# ── External API URLs ─────────────────────────────────────────────────────────
ALQURAN_API_URL=https://api.alquran.cloud/v1
TAFSIR_CDN_URL=https://cdn.jsdelivr.net/gh/spa5k/tafsir_api@main/tafsir/en-tafisr-ibn-kathir
