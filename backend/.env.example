# Supabase — create a project at https://supabase.com
# 1. Enable pgvector: run "CREATE EXTENSION IF NOT EXISTS vector;" in the SQL Editor
# 2. Run supabase/migrations/001_verses.sql in the SQL Editor
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# OpenAI — used for text-embedding-3-small embeddings
OPENAI_API_KEY=key-here

# Anthropic — used for Claude generation
ANTHROPIC_API_KEY=key-here
